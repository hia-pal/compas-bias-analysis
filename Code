# Chart 6 — False positive and false negative rates by race
error_data = {'Race': [], 'Error Type': [], 'Rate': []}

for race in ['African-American', 'Caucasian']:
    subset = df[df['race'] == race]
    fp = len(subset[(subset['high_risk']==True) & (subset['is_recid']==0)]) / len(subset) * 100
    fn = len(subset[(subset['high_risk']==False) & (subset['is_recid']==1)]) / len(subset) * 100
    error_data['Race'].extend([race, race])
    error_data['Error Type'].extend(['False Positive\n(wrongly flagged dangerous)',
                                        'False Negative\n(wrongly flagged safe)'])
    error_data['Rate'].extend([fp, fn])

error_df = pd.DataFrame(error_data)

plt.figure(figsize=(9, 5))
x = [0, 1]
width = 0.35
aa = error_df[error_df['Race']=='African-American']['Rate'].values
ca = error_df[error_df['Race']=='Caucasian']['Rate'].values

bars1 = plt.bar([i - width/2 for i in x], aa, width, label='African-American', color='#E24B4A')
bars2 = plt.bar([i + width/2 for i in x], ca, width, label='Caucasian', color='#378ADD')

for bar in list(bars1) + list(bars2):
    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.3,
             f'{bar.get_height():.1f}%', ha='center', fontsize=10, fontweight='bold')

plt.xticks(x, ['False Positive\n(wrongly flagged dangerous)',
               'False Negative\n(wrongly flagged safe)'])
plt.ylabel('% of Defendants')
plt.title('Algorithm Error Rates by Race', fontsize=14, fontweight='bold')
plt.legend()
plt.tight_layout()
plt.savefig('chart6_errors.png', dpi=150)
plt.show()

