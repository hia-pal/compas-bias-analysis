    'mean', 'median'
]).round(2)
# High risk = decile score 8, 9, or 10
df['high_risk'] = df['decile_score'] >= 8

high_risk_pct = df.groupby('race')['high_risk'].mean() * 100
print(high_risk_pct.round(1))
# False positive = labelled high risk but did NOT reoffend
# False negative = labelled low risk but DID reoffend

for race in ['African-American', 'Caucasian']:
    subset = df[df['race'] == race]

    fp = subset[(subset['high_risk'] == True) &
                (subset['is_recid'] == 0)]

    fn = subset[(subset['high_risk'] == False) &
                (subset['is_recid'] == 1)]

    fp_rate = len(fp) / len(subset) * 100
    fn_rate = len(fn) / len(subset) * 100

    print(f"\n{race}")
    print(f"  False positive rate: {fp_rate:.1f}%")
    print(f"  False negative rate: {fn_rate:.1f}%")

Visualization:
# Chart 1 — Average risk score by race
import matplotlib.pyplot as plt
import seaborn as sns

avg_scores = df.groupby('race')['decile_score'].mean()

plt.figure(figsize=(7, 5))
colors = ['#E24B4A', '#378ADD']
bars = plt.bar(avg_scores.index, avg_scores.values, color=colors, width=0.5, edgecolor='white')

# Add value labels on top of bars
for bar in bars:
    plt.text(bar.get_x() + bar.get_width()/2,
             bar.get_height() + 0.05,
             f'{bar.get_height():.2f}',
             ha='center', fontsize=12, fontweight='bold')

plt.title('Average COMPAS Risk Score by Race', fontsize=14, fontweight='bold')
plt.ylabel('Average Decile Score (1-10)')
plt.ylim(0, 8)
plt.axhline(y=5, color='gray', linestyle='--', alpha=0.5, label='Score of 5 (midpoint)')
plt.legend()
plt.tight_layout()
plt.savefig('chart1_avg_score.png', dpi=150)
plt.show()
