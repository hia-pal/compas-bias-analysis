# Chart 4 — Score by race AND priors (grouped)
# Group priors into buckets for cleaner chart
df['priors_bucket'] = pd.cut(df['priors_count'],
    bins=[-1, 0, 2, 5, 100],
    labels=['0 priors', '1-2 priors', '3-5 priors', '6+ priors'])

grouped = df.groupby(['priors_bucket', 'race'])['decile_score'].mean().unstack()

ax = grouped.plot(kind='bar', figsize=(10, 6),
                  color=['#E24B4A', '#378ADD'],
                  edgecolor='white', width=0.6)

